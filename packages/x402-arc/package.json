{
  "name": "x402-arc",
  "version": "0.1.0",
  "description": "x402 escrow payment gateway SDK for Arc (Circle's L1)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
